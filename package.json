{
  "name": "kilid",
  "version": "0.1.0",
  "description": "Fast, zero-dependency TypeScript keyboard, mouse and pointer management with a Monaco-style keybinding API",
  "keywords": [
    "keyboard",
    "keybinding",
    "shortcut",
    "hotkey",
    "chord",
    "mouse",
    "pointer",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farskid/kilid.git"
  },
  "bugs": {
    "url": "https://github.com/farskid/kilid/issues"
  },
  "homepage": "https://github.com/farskid/kilid#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test",
    "bench": "vitest bench --run",
    "prepublishOnly": "npm run build && npm run typecheck && npm test"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "happy-dom": "^18.0.1",
    "serve": "^14.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
